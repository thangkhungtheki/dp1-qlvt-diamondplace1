<% 
  var ngayHienTai = new Date();
  var ngayHienTaiFormatted = ngayHienTai.toISOString().split('T')[0];
%>

<div class="card shadow mb-4">
  <div class="card-header py-3">
    <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-plus-circle"></i> THÊM CÔNG VIỆC ĐỊNH KỲ MỚI</h6>
  </div>
  <div class="card-body">
    <form action="/house/cv/create" method="POST">
      <div class="row">
        <div class="form-group col-md-6">
          <label><b>Tên Công Việc</b></label>
          <input type="text" class="form-control" name="tencv" placeholder="VD: Vệ sinh máy lạnh" required>
        </div>
        <div class="form-group col-md-6">
          <label><b>Vị Trí / Khu vực</b></label>
          <input type="text" class="form-control" name="vitri" placeholder="VD: Tầng 1 - Ruby">
        </div>

        <div class="form-group col-md-4">
          <label><b>Loại định kỳ</b></label>
          <select name="loai_dinh_ky" id="selLoai" class="form-control" onchange="toggleFields()">
            <option value="tuan">Hàng Tuần</option>
            <option value="thang">Hàng Tháng</option>
            <option value="quy">Hàng Quý</option>
            <option value="custom">Tùy chỉnh</option>
          </select>
        </div>

        <div class="form-group col-md-4" id="divThu">
          <label>Thứ trong tuần (VD: 2,4,6)</label>
          <input type="text" class="form-control" name="thu_trong_tuan" placeholder="2,4,6">
        </div>

        <div class="form-group col-md-4" id="divNgay" style="display:none;">
          <label>Ngày trong tháng (VD: 1,15)</label>
          <input type="text" class="form-control" name="ngay_trong_thang" placeholder="1,15,30">
        </div>

        <div class="form-group col-md-4">
          <label>Mức độ</label>
          <select name="muc_do" class="form-control">
            <option value="trung_binh">Trung bình</option>
            <option value="thap">Thấp</option>
            <option value="cao">Cao 🔥</option>
          </select>
        </div>

        <div class="form-group col-md-4">
          <label>Số ngày thực hiện (Thời hạn)</label>
          <input type="number" class="form-control" name="so_ngay_thuc_hien" value="1">
        </div>
        <div class="form-group col-md-4">
          <label>Nhắc trước (Số ngày gửi mail)</label>
          <input type="number" class="form-control" name="so_ngay_nhac_truoc" value="3">
        </div>
        <div class="form-group col-md-4">
          <label>Người phụ trách</label>
          <input type="text" class="form-control" name="nguoi_phu_trach" placeholder="Tên nhân viên">
        </div>

        <div class="form-group col-md-12">
          <label>Ghi chú / Mô tả chi tiết</label>
          <textarea class="form-control" name="mo_ta" rows="3"></textarea>
        </div>

        <div class="form-group col-md-6">
          <div class="custom-control custom-switch mt-2">
            <input type="checkbox" class="custom-control-input" id="swLap" name="laplai" value="true" checked>
            <label class="custom-control-label" for="swLap">Tự động lặp lại khi hết hạn</label>
          </div>
        </div>
      </div>

      <hr>
      <div class="form-group">
        <button type="submit" class="btn btn-primary shadow-sm"><i class="fas fa-save"></i> LƯU CÔNG VIỆC</button>
        <button type="button" class="btn btn-secondary shadow-sm" onclick="window.location.href='/house/cv'"><i class="fas fa-list"></i> XEM DANH SÁCH</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleFields() {
    var loai = document.getElementById('selLoai').value;
    var dThu = document.getElementById('divThu');
    var dNgay = document.getElementById('divNgay');

    if (loai === 'tuan') {
      dThu.style.display = 'block';
      dNgay.style.display = 'none';
    } else {
      dThu.style.display = 'none';
      dNgay.style.display = 'block';
    }
  }
</script>